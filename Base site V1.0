<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PTFS Ryanair</title>
  <style>
    body { margin:0; font-family: Arial, sans-serif; background:#f1f5f9; color:#0f172a; }
    header { background:#073590; color:white; padding:20px 40px; position:sticky; top:0; }
    nav button, .logo { background:none; border:none; color:white; cursor:pointer; margin-right:20px; }
    .hero { background:linear-gradient(to right, #073590, #3b82f6); color:white; padding:80px 40px; display:grid; grid-template-columns:1fr 1fr; gap:40px; }
    .booking, .card { background:white; border-radius:20px; padding:24px; box-shadow:0 8px 20px rgba(0,0,0,0.1); }
    .booking input { width:calc(50% - 10px); padding:12px; margin:5px; border:1px solid #cbd5e1; border-radius:10px; }
    .btn { padding:14px 20px; border:none; border-radius:14px; cursor:pointer; font-weight:bold; }
    .yellow { background:#facc15; }
    .blue { background:#073590; color:white; width:100%; margin-top:15px; }
    .cards { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; padding:60px 40px; }
    .placeholder { height:120px; background:#cbd5e1; border-radius:14px; margin-bottom:15px; }
    #message { margin-top:15px; color:#475569; }
  </style>
</head>
<body>
  <header>
    <button class="logo" onclick="window.scrollTo({top:0,behavior:'smooth'})"><b>RYANAIR</b></button>
    <nav style="display:inline-block; margin-left:30px;">
      <button onclick="window.scrollTo({top:0,behavior:'smooth'})">Flights</button>
      <button onclick="document.getElementById('deals').scrollIntoView({behavior:'smooth'})">Hotels</button>
      <button onclick="document.getElementById('deals').scrollIntoView({behavior:'smooth'})">Cars</button>
      <button onclick="document.getElementById('deals').scrollIntoView({behavior:'smooth'})">Fleet</button>
    </nav>
  </header>

  <section class="hero">
    <div>
      <h1 style="font-size:56px; margin:0;">Catch Flights, Not Delays</h1>
      <p>This version actually works in Google Sites embeds, because apparently the web enjoys making simple things annoying.</p>
      <button class="btn yellow" onclick="searchFlights()">Book now</button>
    </div>

    <div class="booking">
      <h2>Book your flight</h2>
      <input id="from" placeholder="From">
      <input id="to" placeholder="To">
      <input id="departure" placeholder="Departure">
      <input id="return" placeholder="Return">
      <button class="btn blue" onclick="searchFlights()">Search flights</button>
      <p id="message"></p>
    </div>
  </section>

  <section id="deals" class="cards">
    <div class="card" onclick="openCard('Cheap Car Hire')"><div class="placeholder"></div><h3>Cheap Car Hire</h3></div>
    <div class="card" onclick="openCard('Stay under €99')"><div class="placeholder"></div><h3>Stay under €99</h3></div>
    <div class="card" onclick="openCard('Flight Training')"><div class="placeholder"></div><h3>Flight Training</h3></div>
    <div class="card" onclick="openCard('Our Fleet')"><div class="placeholder"></div><h3>Our Fleet</h3></div>
  </section>

  <script>
    function searchFlights() {
      const from = document.getElementById('from').value;
      const to = document.getElementById('to').value;
      const departure = document.getElementById('departure').value;
      const ret = document.getElementById('return').value;
      const message = document.getElementById('message');

      if (!from || !to) {
        message.innerText = 'Fill in departure and destination first.';
        return;
      }

      message.innerText = `Searching flights from ${from} to ${to}${departure ? ' on ' + departure : ''}${ret ? ' returning ' + ret : ''}.`;
    }

    function openCard(name) {
      document.getElementById('message').innerText = 'Opening ' + name;
    }
  </script>
</body>
</html>
